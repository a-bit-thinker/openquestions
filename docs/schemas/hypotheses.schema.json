{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/schemas/hypotheses.schema.json",
  "type": "object",
  "required": ["version", "hypotheses"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "updated_utc": {"type": "string"},
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement"],
        "properties": {
          "hypothesis_id": {"type": "string"},
          "retired_id": {"type": "string"},
          "statement": {"type": "string", "minLength": 15},
          "expected_metric_movement": {"type": "array", "items": {"type": "string"}},
          "falsification_condition": {"type": "string"},
          "related_claims": {"type": "array", "items": {"type": "string"}},
          "retire_reason": {"type": "string"},
          "evidence_ref": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
